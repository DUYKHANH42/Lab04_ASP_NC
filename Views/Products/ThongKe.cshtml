@using Lab04.VM
@model List<ThongKeVM>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<div class="container mt-4">
    <h2 class="mb-4">Thống kê sản phẩm theo danh mục</h2>
    <table class="table table-bordered table-hover text-center">
        <thead class="table-dark">
            <tr>
                <th>Tên danh mục</th>
                <th>Số lượng SP</th>
                <th>Giá lớn nhất</th>
                <th>Giá nhỏ nhất</th>
                <th>Giá trung bình</th>
                <th>Tổng giá trị</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.TenDanhMuc</td>
                    <td>@item.SoLuongSanPham</td>
                    <td>@item.GiaLonNhat.ToString("N0") VNĐ</td>
                    <td>@item.GiaNhoNhat.ToString("N0") VNĐ</td>
                    <td>@item.GiaTrungBinh.ToString("N0") VNĐ</td>
                    <td>@item.TongGiaTri.ToString("N0") VNĐ</td>
                </tr>
            }
        </tbody>
    </table>
</div>