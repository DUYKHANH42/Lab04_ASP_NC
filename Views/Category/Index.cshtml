@model List<Category>

@{
    ViewData["Title"] = "Danh sách danh mục";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-4">
    <h2 class="mb-3">Danh sách danh mục</h2>

    <a asp-action="Create" class="btn btn-primary mb-3">Thêm danh mục</a>
    <div asp-validation-summary="All" class="text-danger mb-3"></div>
    <table class="table table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>Tên danh mục</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Name</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Sửa</a>
                        <a asp-action="Delete" onclick="return confirm('Xác nhận xóa danh mục')" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Xóa</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}